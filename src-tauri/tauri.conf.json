{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KaikeiVoice",
  "version": "0.1.1",
  "identifier": "com.kaikei.voiceinput",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "音声入力 → 弥生CSV（小口）",
        "width": 1180,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
