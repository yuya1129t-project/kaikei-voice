{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KaikeiVoice",
  "version": "0.1.39",
  "identifier": "com.kaikei.voiceinput",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "音声入力 → 弥生CSV（小口）",
        "width": 1180,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/sherpa-onnx-offline-websocket-server"],
    "macOS": {
      "minimumSystemVersion": "14.0",
      "signingIdentity": "Developer ID Application: Yuya Tanaka (36NS5GY6R7)",
      "entitlements": "entitlements.plist"
    },
    "windows": { "nsis": { "installerHooks": "nsis-hooks.nsh" } },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/yuya1129t-project/kaikei-voice/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU4Mzc3RjRGQ0UwNTE5NDIKUldSQ0dRWE9UMzgzV0ZHSG92MVhjYmNwVis4QnpJdjRPTzlPamlPSVN2ZUNLSlRDMyt0QlZTRS8K"
    }
  }
}
